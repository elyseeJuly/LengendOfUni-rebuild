{
  "$schema": "https://raw.githubusercontent.com/nicklasxyz/tauri-v2-schemas/main/tauri.conf.schema.json",
  "productName": "宇宙群英传",
  "version": "1.0.0",
  "identifier": "com.emberois.legend-of-uni",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "宇宙群英传",
        "width": 1600,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1024,
        "minHeight": 768
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": null,
      "nsis": null
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}